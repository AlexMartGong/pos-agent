<service>
  <id>POSPrinterAgent</id>
  <name>POS Printer Agent</name>
  <description>Agente de impresion para terminales POS - La Pasadita</description>
  <executable>run-agent.bat</executable>
  <arguments></arguments>
  <workingdirectory>%BASE%</workingdirectory>

  <!-- Logging -->
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>3</keepFiles>
  </log>

  <!-- Auto restart on failure -->
  <onfailure action="restart" delay="5 sec"/>
  <resetfailure>10 sec</resetfailure>

  <!-- Start automatically -->
  <startmode>Automatic</startmode>

  <!-- Stop timeout -->
  <stoptimeout>15 sec</stoptimeout>
</service>
